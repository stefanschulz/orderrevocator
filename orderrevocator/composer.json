{
  "name": "the-loom/orderrevocator",
  "description": "Revoke an order",
  "minimum-stability": "stable",
  "license": "AFL-3.0",
  "type": "prestashop-module",
  "authors": [
    {
      "name": "Stefan",
      "email": "schulz@the-loom.de"
    }
  ],
  "require": {
    "php": ">=8.4",
    "ext-zip": "*"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "v3.41.1",
    "prestashop/php-dev-tools": "^5.0",
    "prestashop/autoindex": "^2.1",
    "phing/phing": "^3.1"
  },
  "autoload": {
    "psr-4": {
      "PrestaShop\\Module\\OrderRevocator\\": "src/"
    },
    "classmap": [
      "orderrevocator.php",
      "controllers/",
      "src/"
    ]
  },
  "config": {
    "preferred-install": "dist",
    "prepend-autoloader": false
  },
  "scripts": {
    "php-cs-fixer": "php-cs-fixer --rules=@PSR1"
  }
}
